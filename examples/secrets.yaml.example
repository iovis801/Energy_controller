# Copia questo file in /config/secrets.yaml e popola con i valori reali.
# Il vero secrets.yaml NON deve mai essere committato (vedi .gitignore).

# Credenziali Bosch HomeCom Easy (app My Home) - per integrazione PdC
bosch_homecom_email: "your-bosch-account@example.com"
bosch_homecom_password: "REPLACE_ME"

# Inverter SMA - rilevato a 192.168.129.1 (SMA3006900576.local)
# Per dati installer chiedere a Brusol.
sma_host: "192.168.129.1"
sma_password: "REPLACE_ME"
sma_group: "user"                  # oppure "installer"

# HomeWizard P1 Meter - rilevato a 192.168.129.33 (p1meter-4309BA.local)
# Normalmente plug-and-play via mDNS, IP solo come backup.
homewizard_p1_host: "192.168.129.33"

# Buderus MX300 (cloud-only, HTTP locale chiuso, gestito da HomeCom Easy)
buderus_mx300_ip: "192.168.129.15"

# Bonus integrazioni rilevate sulla LAN (opzionali, da abilitare in futuro)
denon_avr_host: "192.168.129.14"       # AV Receiver Denon AVR-X2800H
nas_netgear_host: "192.168.129.5"      # NAS ReadyNAS (UPS monitor via NUT su 3493)
nas_netgear_nut_port: 3493

# Notifiche push (companion app HA)
notify_target: "mobile_app_pixel_8"   # REPLACE con il device id reale
